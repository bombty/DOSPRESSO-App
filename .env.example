# DOSPRESSO Environment Variables
# Copy this file to .env and fill in the values

# Database Configuration
DATABASE_URL=postgresql://username:password@host:port/database
PGHOST=your-postgres-host
PGPORT=5432
PGUSER=your-postgres-user
PGPASSWORD=your-postgres-password
PGDATABASE=dospresso

# Session Secret (generate a random secure string)
SESSION_SECRET=your-secure-random-session-secret-here

# SMTP Email Configuration (IONOS or other provider)
SMTP_HOST=smtp.ionos.com
SMTP_PORT=587
SMTP_USER=your-email@yourdomain.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=noreply@yourdomain.com

# Object Storage (AWS S3 or compatible)
DEFAULT_OBJECT_STORAGE_BUCKET_ID=your-bucket-id
PUBLIC_OBJECT_SEARCH_PATHS=public
PRIVATE_OBJECT_DIR=.private

# Optional: OpenAI API Key (for AI features)
# OPENAI_API_KEY=sk-your-openai-api-key-here

# Admin Bootstrap Password (initial admin account setup)
ADMIN_BOOTSTRAP_PASSWORD=your-secure-admin-password

# Web Push Notifications (VAPID keys)
# Generate with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=your-vapid-public-key
# VAPID_PRIVATE_KEY=your-vapid-private-key

# Node Environment
NODE_ENV=production
PORT=5000

# ═══════════════════════════════════════════════════════════════════
# PILOT GÜVENLIK KONTROLLERİ (21 Nis 2026 - S-Bordro Sprint)
# ═══════════════════════════════════════════════════════════════════
# Pilot süresince (28 Nis - 5 May 2026) bu değişkenler set edilir.
# Production'da BOŞ veya unset bırakılır.

# Bordro hesaplaması için data source kilidi
# Değerler: kiosk | excel | manual | (boş)
# Boş = kilitsiz (normal çalışma)
# kiosk = Mahmut excel seçse bile kiosk verisi kullanılır
# Pilot ayarı: kiosk
PAYROLL_LOCKED_DATASOURCE=

# DRY_RUN modu: true ise bordro hesaplanır+kaydedilir AMA SGK bildirimi YAPILMAZ
# Değerler: true | false
# Pilot ayarı: true (ilk ay test için)
PAYROLL_DRY_RUN=false

# Mola eşiği geçici override (dakika cinsinden)
# 0 = kullanma (DB/varsayılan 90dk geçerli)
# Pilot ayarı: 120 (bildirim spam önleme için 90→120 yumuşatma)
PILOT_BREAK_MINUTES_OVERRIDE=0

# PDKS Excel Import devre dışı bırak (pilot süresince)
# Değerler: true | false (default boş = false)
# Pilot ayarı: false (Excel upload + calculate endpoint'leri 503 döner)
# Production ayarı: true (Mahmut bordro için Excel kullanabilir)
# NOT: READ endpoint'leri (list, mappings, records) her zaman açık
PDKS_EXCEL_IMPORT_ENABLED=false
