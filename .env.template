# ============================================
# DOSPRESSO Franchise Management WebApp
# Environment Configuration Template
# ============================================
# Copy this file to .env and fill in your values
# cp .env.template .env
# ============================================

# ============================================
# DOMAIN & SSL
# ============================================
# Your domain name (without http/https)
DOMAIN=dospresso.example.com

# Admin email for Let's Encrypt SSL certificates
ADMIN_EMAIL=admin@example.com

# ============================================
# DATABASE
# ============================================
POSTGRES_DB=dospresso
POSTGRES_USER=dospresso
POSTGRES_PASSWORD=your-secure-password-here

# Full database URL (auto-generated in docker-compose)
# DATABASE_URL=postgresql://dospresso:your-password@postgres:5432/dospresso

# ============================================
# SESSION & SECURITY
# ============================================
# Generate a strong secret: openssl rand -base64 32
SESSION_SECRET=your-session-secret-here-minimum-32-characters

# ============================================
# SMTP EMAIL SETTINGS
# ============================================
SMTP_HOST=smtp.ionos.de
SMTP_PORT=587
SMTP_USER=your-email@domain.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=noreply@dospresso.com

# ============================================
# OPENAI API (for AI features)
# ============================================
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# ============================================
# OBJECT STORAGE (AWS S3 or compatible)
# ============================================
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=eu-central-1
S3_BUCKET=dospresso-uploads

# ============================================
# TRAEFIK DASHBOARD (optional)
# ============================================
# Generate password: htpasswd -nb admin your-password
# TRAEFIK_AUTH=admin:$apr1$xyz$abc

# ============================================
# ADMIN & SECURITY
# ============================================
ADMIN_BOOTSTRAP_PASSWORD=your-secure-admin-password

# ============================================
# WEB PUSH NOTIFICATIONS (VAPID)
# ============================================
# Generate keys with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# ============================================
# OPTIONAL SETTINGS
# ============================================
# NODE_ENV=production
# PORT=5000
