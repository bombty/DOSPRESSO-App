  app.patch('/api/admin/module-visibility/:moduleId', isAuthenticated, async (req: any, res) => {
    try {
      const user = req.user!;
      if (user.role !== 'admin') {
        return res.status(403).json({ message: 'Yetkiniz yok' });
      }
      const { moduleId } = req.params;
