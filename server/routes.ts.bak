      const enriched = assignments.map((a: any) => {
        const assignedUser = allUsers.find(u => u.id === a.userId);
        return {
          ...a,
          user: assignedUser ? { 
            id: assignedUser.id, 
            firstName: assignedUser.firstName, 
            lastName: assignedUser.lastName,
            role: assignedUser.role 
          } : null,
        };
      });
      
      res.json(enriched);
    } catch (error: any) {
